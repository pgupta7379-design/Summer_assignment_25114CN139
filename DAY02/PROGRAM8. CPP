#include<iostream>
using namespace std;

int main()
{
    int n, Original, Reverse = 0, Remainder;

    cout<<"Enter Number : ";
    cin>>n;

    Original = n;

    while(n > 0)
    {
        Remainder = n % 10;
        Reverse = Reverse * 10 + Remainder;
        n = n / 10;
    }

    if(Original == Reverse)
    {
        cout<<"Palindrome Number";
    }
    else
    {
        cout<<"Not a Palindrome Number";
    }

    return 0;
}
